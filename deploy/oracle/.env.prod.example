# Copy this file to deploy/oracle/.env.prod and replace values.

APP_SECRET=change_this_to_a_long_random_secret
DB_PASSWORD=ChangeThisStrongPassword!2026
JWT_PASSPHRASE=change_this_jwt_passphrase

# For production, set your public origins (frontend domain and optional HF Space domain).
# Example:
# ^https?://(your-frontend-domain\\.com|your-space-name\\.hf\\.space)(:[0-9]+)?$
CORS_ALLOW_ORIGIN=^https?://(localhost|127\\.0\\.0\\.1|152\\.70\\.53\\.27)(:[0-9]+)?$
